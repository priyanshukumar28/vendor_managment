generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  VENDOR_ADMIN
  DEVELOPER
  BUSINESS_APPROVER
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  DELAYED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum RatingLevel {
  EXCELLENT
  GOOD
  AVERAGE
  NEEDS_IMPROVEMENT
  CRITICAL
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CHANGES_REQUESTED
}

enum ApprovalType {
  REQUIREMENT
  UAT
  PRODUCTION
}

model Vendor {
  id String @id @default(uuid())

  vendorDisplayId String? @unique
  vendorCode      String? @unique

  name  String
  email String? @unique

  users    User[]
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id String @id @default(uuid())

  employeeId String? @unique

  name     String
  email    String @unique
  password String

  role Role

  vendorId String?
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  tasks Task[]

  developerProfile DeveloperProfile?
  approvalsGiven   Approval[]        @relation("ApprovalApprovedBy")

  comments TaskComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id String @id @default(uuid())

  projectDisplayId String? @unique

  name        String
  description String?

  status ProjectStatus @default(PLANNING)

  progress Int @default(0)

  deadline DateTime?

  vendorId String
  vendor   Vendor @relation(fields: [vendorId], references: [id])

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id String @id @default(uuid())

  title       String
  description String?

  status TaskStatus @default(PENDING)

  priority Priority @default(MEDIUM)

  startDate DateTime?
  endDate   DateTime?

  remarks String?

  comments TaskComment[]

  approvals Approval[]

  businessApprovalRequired Boolean   @default(false)
  businessApprovalDueDate  DateTime?

  escalations Escalation[]

  assignedToId String
  assignedTo   User   @relation(fields: [assignedToId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id String @id @default(uuid())

  action String

  entityType String?
  entityId   String?

  userId String

  metadata Json?

  createdAt DateTime @default(now())
}

model DeveloperProfile {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productivityScore Float @default(0)
  approvalRate      Float @default(0)
  qualityScore      Float @default(0)
  delayFrequency    Float @default(0)

  tasksCompleted Int @default(0)
  tasksDelayed   Int @default(0)

  rating RatingLevel @default(AVERAGE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TaskComment {
  id String @id @default(uuid())

  comment String

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Approval {
  id String @id @default(uuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  approvedById String?
  approvedBy   User?   @relation("ApprovalApprovedBy", fields: [approvedById], references: [id])

  type ApprovalType

  status ApprovalStatus @default(PENDING)

  remarks String?

  approvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Escalation {
  id String @id @default(uuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  severity String

  reason String

  resolved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
